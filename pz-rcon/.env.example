# Project Zomboid RCON credentials
PZ_RCON_HOST=YOUR_SERVER_IP
PZ_RCON_PORT=17000
PZ_RCON_PASSWORD='CHANGE_ME'

# Server name (used in Discord channel name and broadcasts)
# Example: pz-molt becomes #pz-molt channel
PZ_SERVER_NAME=pz-molt

# Discord config
# Channel ID for server chat relay (format: {server_name} → #pz-molt)
PZ_DISCORD_CHANNEL_ID=
